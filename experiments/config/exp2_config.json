    "fault_params": {"probability": 1.0, "magnitude_min_m": 100, "magnitude_max_m": 500},
    "occlusion_params": {"angle_deg": 45, "elevation_cutoff_deg": 30},
    "fde_params": {"P_FA": 1e-5, "max_exclusions": 3, "min_sats_after_exclusion": 5}
  },
  "metrics": ["P_md", "P_fa", "n_HMI", "stanford_plot", "FDE_detection_rate", "FDE_exclusion_count"]
}
