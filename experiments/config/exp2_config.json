{
  "experiment": "exp2_stanford_pl",
  "data_generator": "experiments/scripts/generate_data_cmm.py",
  "generation_params": {
    "count": 3,
    "points": 200,
    "speed_mps": 12.0,
    "sample_rate_hz": 1.0,
    "num_sats": 8,
